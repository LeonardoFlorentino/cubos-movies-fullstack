PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=cubos
DB_PASSWORD=cubos
DB_NAME=cubos_movies

JWT_SECRET=dev-secret
JWT_EXPIRES_IN=1d

# Storage
# Use one provider: s3 or r2
STORAGE_PROVIDER=s3

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Optional. If empty, API will build:
# https://<bucket>.s3.<region>.amazonaws.com/<key>
AWS_S3_PUBLIC_BASE_URL=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
# Optional if R2_ACCOUNT_ID is set.
R2_ENDPOINT=
R2_BUCKET=
# Required when using R2
R2_PUBLIC_BASE_URL=
